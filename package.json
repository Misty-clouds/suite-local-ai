{
  "name": "suite",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "build:api": "pnpm --filter @suite/api build",
    "start": "node apps/api/dist/main.js",
    "start:api": "node apps/api/dist/main.js",
    "postinstall": "node scripts/postinstall-build.mjs",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "clean": "turbo run clean && rm -rf node_modules",
    "infra:up": "docker compose up db redis kong auth rest realtime storage imgproxy meta studio -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
