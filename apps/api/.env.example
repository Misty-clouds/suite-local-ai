# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker Compose host: db   |   Local dev host: localhost
DATABASE_URL=postgresql://postgres:your-super-secret-password@localhost:5432/suites

# ─── Redis ────────────────────────────────────────────────────────────────────
# Docker Compose host: redis   |   Local dev host: localhost
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT_SECRET=change-me-in-production
# JWT_EXPIRES_IN=7d
