# ─── Server ───────────────────────────────────────────────────────────────────
# 5050 by default — port 5000 collides with macOS AirPlay Receiver / Control Center.
PORT=5050
NODE_ENV=development

# ─── Database (MongoDB) ───────────────────────────────────────────────────────
# Local dev:        mongodb://localhost:27017/suite
# Docker Compose:   mongodb://mongo:27017/suite
# MongoDB Atlas:    mongodb+srv://<user>:<pass>@<cluster>/suite?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/suite

# ─── Redis ────────────────────────────────────────────────────────────────────
# Docker Compose host: redis   |   Local dev host: localhost
REDIS_URL=redis://localhost:6379

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
# Use long, random, DISTINCT secrets in production (e.g. `openssl rand -hex 32`).
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── Finance Agent (Cloudstech Finance Operations Agent) ──────────────────────
# Shared secret the ADK agent sends as `x-agent-token` to call /tools/*.
AGENT_SERVICE_TOKEN=change-me-agent-service-token

# Plaid (Sandbox) — https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Google Cloud / Vertex AI Agent Engine
GOOGLE_CLOUD_PROJECT=
VERTEX_LOCATION=us-central1
AGENT_ENGINE_URL=
# Path to the service-account JSON (or use ADC)
GOOGLE_APPLICATION_CREDENTIALS=

# BigQuery (analytics destination Fivetran syncs into)
BIGQUERY_DATASET=cloudstech_finance

# Fivetran — https://fivetran.com  (REST API + MCP server)
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=
FIVETRAN_CONNECTOR_ID=
FIVETRAN_MCP_URL=
