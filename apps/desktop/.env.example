# Suite Desktop — on-device AI (QVAC SDK) configuration
# (Untracked. The desktop app runs all inference locally; no cloud AI keys.)

# Which model the QVAC SDK loads for the finance assistant.
# Either a built-in model constant name (downloads out-of-the-box) …
#   QWEN3_1_7B_INST_Q4   (default — small, fast, good instruct quality)
#   QWEN3_600M_INST_Q4   (tiny — lowest-spec hardware)
#   LLAMA_3_2_1B_INST_Q4_0
# … or a custom modelSrc: a local *.gguf path or a remote GGUF URL to any
# llama.cpp-compatible model (e.g. a QVAC / MedPsy model you have access to).
QVAC_MODEL=QWEN3_1_7B_INST_Q4

# Where the desktop window loads the dashboard from in dev (the running web app).
SUITE_WEB_URL=http://localhost:3001
