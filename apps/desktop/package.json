{
  "name": "@suite/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Suite desktop app — wraps the web dashboard and runs all AI inference on-device via the QVAC SDK.",
  "main": "dist/main.js",
  "scripts": {
    "build:electron": "tsc -p tsconfig.json",
    "dev": "pnpm build:electron && wait-on http-get://localhost:3001 && electron .",
    "start": "pnpm build:electron && electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "pnpm build:electron && electron-builder"
  },
  "dependencies": {
    "@qvac/sdk": "^0.13.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "org.cloudstech.suite.desktop",
    "productName": "Suite",
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/.next/standalone",
        "to": "web"
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
