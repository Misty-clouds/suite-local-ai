# Cloudstech Finance Agent (Vertex ADK) — environment

# NestJS API the tools call (use a public URL when deployed to Agent Engine)
SUITE_API_URL=http://localhost:5050
AGENT_SERVICE_TOKEN=

# Gemini / Vertex
AGENT_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_PROJECT=
VERTEX_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE
AGENT_STAGING_BUCKET=gs://your-staging-bucket

# BigQuery (Fivetran destination)
BIGQUERY_DATASET=cloudstech_finance

# Fivetran (the MCP launches via uvx with these)
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=
FIVETRAN_ALLOW_WRITES=true
