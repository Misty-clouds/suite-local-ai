# ─── Supabase Postgres ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-password
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ─── Supabase JWT ─────────────────────────────────────────────────────────────
# Must be at least 32 characters. Used to sign all Supabase JWTs.
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# Pre-generated tokens for the default dev JWT_SECRET above.
# Regenerate these if you change JWT_SECRET:
#   https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlhdCI6MTYxMzUzMTk4NSwiZXhwIjoxOTI5MTA3OTg1fQ.ReNhHIoSMU2ULnpRUqzt47Z5G0LFNkR-xnNsJvBuOBo
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNjEzNTMxOTg1LCJleHAiOjE5MjkxMDc5ODV9.th84OKK0Ou9SEiml1pxFjyVlWFsHMQkHGRkkhE7CgiM

# ─── Supabase URLs ────────────────────────────────────────────────────────────
# Public URL of the Kong API gateway (change to your domain in production)
SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000
# Your app's site URL (used for auth redirects)
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

# ─── Supabase Kong ────────────────────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# ─── Supabase Studio ──────────────────────────────────────────────────────────
STUDIO_PORT=54323
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Suites

# ─── Supabase Auth ────────────────────────────────────────────────────────────
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false

# ─── SMTP (optional — needed for auth emails) ─────────────────────────────────
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Suites

# ─── Supabase Storage ─────────────────────────────────────────────────────────
STORAGE_BACKEND=file
GLOBAL_S3_BUCKET=stub
IMGPROXY_ENABLE_WEBP_DETECTION=true

# ─── Supabase Realtime ────────────────────────────────────────────────────────
# Must be at least 64 characters
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
